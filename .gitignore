# ═══════════════════════════════════════════════
# ASO-DEMO Project — Git Ignore Rules
# ═══════════════════════════════════════════════

# ── Antigravity / AI tools ──
.understand-anything/
.pytest_cache/

# ── Python cache ──
__pycache__/
*.py[cod]
*.pyo

# ── Data files (mỗi máy có data riêng) ──
# CSV đầu vào từ AppTweak
*/Input/

# Excel kết quả sau lọc
*/Output/

# Master Keywords export
Master_Keywords/

# SQLite database (Keyword Tracker)
Keyword_Tracker/keyword_tracker.db

# Scoped interactive selection cache
*/.cache/
.cache/

# ── IDE & Editor ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS files ──
Thumbs.db
Desktop.ini
.DS_Store

# ── Compressed archives ──
*.zip

# ── Logs ──
*.log

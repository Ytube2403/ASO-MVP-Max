# ═══════════════════════════════════════════════
# ASO-MVP Project — Git Ignore Rules
# ═══════════════════════════════════════════════

# ── Antigravity / AI tools ──
.understand-anything/
.pytest_cache/
.env
.env.*
!.env.example

# ── Python cache ──
__pycache__/
*.py[cod]
*.pyo
.venv-libretranslate/

# ── Data files (mỗi máy có data riêng) ──
# Legacy nested workspace accidentally committed before the ASO-MVP cleanup.
/ASO-DEMO/

# CSV đầu vào từ AppTweak
apps/*/Input/
!apps/Prank_Sounds/Input/
!apps/Prank_Sounds/Input/052026/
!apps/Prank_Sounds/Input/052026/*.csv

# Excel kết quả sau lọc
apps/*/Output/

# Master Keywords export
data/master_keywords/

# SQLite database (Keyword Tracker)
tracker/keyword_tracker.db

# Scoped interactive selection cache
apps/*/.cache/
.cache/

# ── IDE & Editor ──
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ── OS files ──
Thumbs.db
Desktop.ini
.DS_Store

# ── Compressed archives ──
*.zip

# ── Logs ──
*.log
